# ─────────────────────────────────────────────────────────────────────────────
# .env.example — template pour apps/web/.env.local
#
# Copier dans apps/web/.env.local et remplir les valeurs.
# Ne JAMAIS committer .env.local (déjà dans .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Directus (back) ──────────────────────────────────────────────────────────
DIRECTUS_URL=http://localhost:8055
DIRECTUS_STATIC_TOKEN=              # Généré dans Directus > Settings > API Tokens

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=                         # openssl rand -hex 32
CSRF_SECRET=                        # openssl rand -hex 32

# ── ISR revalidation ─────────────────────────────────────────────────────────
NEXT_REVALIDATE_TOKEN=              # openssl rand -hex 24

# ── URLs publiques (injectées dans le HTML) ───────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055
NEXT_PUBLIC_DIRECTUS_ASSETS=http://localhost:8055/assets/
NEXT_PUBLIC_APP_ENV=development

# ── Modules (true / false) ───────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_CORE_PAGES=true
NEXT_PUBLIC_ENABLE_BLOG=true
NEXT_PUBLIC_ENABLE_PRODUCTS=false
NEXT_PUBLIC_ENABLE_AUTH=true
NEXT_PUBLIC_ENABLE_ADMIN=true

# ── Infra locale Docker (lue par infra/local/docker-compose.yml) ──────────────
POSTGRES_DB=app_db
POSTGRES_USER=app
POSTGRES_PASSWORD=app_dev         # dev only — changer en prod
DIRECTUS_SECRET=dev-secret-change-me
DIRECTUS_ADMIN_EMAIL=admin@local.dev
DIRECTUS_ADMIN_PASSWORD=admin123    # dev only — changer en prod
