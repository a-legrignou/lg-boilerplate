# Variables d'environnement pour Dokploy
# Copiez vers .env et ajustez

# Base de données
DATABASE_URL=postgresql://user:password@postgres:5432/app_db

# Redis
REDIS_URL=redis://redis:6379

# Directus
DIRECTUS_URL=http://directus:8055
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=admin123
DIRECTUS_SECRET=your-secret-key
DIRECTUS_PUBLIC_URL=https://yourdomain.com/directus
DIRECTUS_ACCESS_TOKEN_TTL=15m
DIRECTUS_REFRESH_TOKEN_TTL=7d

# Next.js
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=your-nextauth-secret

# Stockage S3 (MinIO)
S3_ENDPOINT=https://minio.yourdomain.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=coreo-assets
S3_REGION=us-east-1

# Modules
ENABLE_BLOG=true
ENABLE_PRODUCTS=false
ENABLE_AUTH=true
ENABLE_ADMIN=true

# SEO
SITE_NAME=Mon Projet
SITE_URL=https://yourdomain.com
SITE_DESCRIPTION=Boilerplate modulaire pour applications web

# Dokploy
DOKPLOY_API_URL=https://dokploy.yourdomain.com
DOKPLOY_API_KEY=your-api-key