{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./packages/config/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./apps/web/src/*"],
      "@ui/*": ["./packages/ui/src/*"],
      "@lib/*": ["./packages/lib/src/*"],
      "@config/*": ["./packages/config/*"]
    }
  },
  "include": ["apps/**/*", "packages/**/*", "modules/**/*", "infra/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts", "**/*.test.ts"]
}
